# Backend URL. Leave empty for local dev (Vite proxies /api to :8000).
# In production set it to the deployed backend, e.g. https://cart-copilot-api.onrender.com
VITE_API_BASE=

# Supabase auth. From your Supabase dashboard > Project Settings > API.
# The anon (public) key is safe in the browser. Never put the service key here.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
